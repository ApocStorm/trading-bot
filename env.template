# Copy to .env locally. Never commit .env.
# In cloud routines, set these as environment variables ON THE ROUTINE itself
# - do NOT create a .env file in the cloud.

# --- Alpaca (paper trading to start) ---
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# --- Perplexity (research) -- OPTIONAL ---
# Leave unset to have perplexity.sh exit 3 and fall back to native WebSearch.
# PERPLEXITY_API_KEY=your_perplexity_api_key_here
# PERPLEXITY_MODEL=sonar

# --- Gmail SMTP (notifications) ---
# GMAIL_APP_PASSWORD is a 16-char app password (not your Google account password).
# Create one at https://myaccount.google.com/apppasswords
GMAIL_USER=kfranks@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
GMAIL_TO=kfranks@gmail.com
